# Copy this file to .env and fill in your values

# ---------------------------------------------------------------------------
# MongoDB Atlas
# ---------------------------------------------------------------------------
MONGODB_URI=mongodb+srv://rishukunwar4020_db_user:<db_password>@cluster0.bczhsmt.mongodb.net/csv_importer?retryWrites=true&w=majority
# ---------------------------------------------------------------------------
# OPTION A: OpenAI (default) - requires billing set up on your OpenAI account
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
# Leave OPENAI_BASE_URL unset/blank to use OpenAI's default endpoint.
OPENAI_BASE_URL=

# ---------------------------------------------------------------------------
# OPTION B: Groq (free tier, no card required) - uncomment and use instead
# Get a key at https://console.groq.com/keys (starts with "gsk_")
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=gsk-your-groq-api-key-here
# OPENAI_MODEL=openai/gpt-oss-20b
# OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Server port
PORT=5000

# Extra allowed origins beyond localhost (comma-separated), needed only in
# production or if the frontend is served from a non-localhost domain.
# Any http://localhost:PORT origin is always allowed automatically, so you
# do NOT need to set this for local development.
CLIENT_ORIGIN=

# Number of CSV records sent to OpenAI per batch
BATCH_SIZE=25
