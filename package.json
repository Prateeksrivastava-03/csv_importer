{
  "name": "csv-importer",
  "version": "1.0.0",
  "private": true,
  "description": "AI-Powered CSV Importer - run both backend and frontend together",
  "scripts": {
    "setup:env": "node scripts/setup-env.js",
    "install:backend": "npm install --prefix backend",
    "install:frontend": "npm install --prefix frontend",
    "install:all": "npm run install:backend && npm run install:frontend && npm run setup:env",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently -n BACKEND,FRONTEND -c blue,green \"npm:dev:backend\" \"npm:dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
